PORT=3000
STENSIBLY_DB=stensibly.sqlite
STENSIBLY_REQUIRE_AUTH=false

# Remote MCP at /mcp always requires a Bearer API token.
# Browser-originated requests are rejected unless the Origin is listed here.
STENSIBLY_ALLOWED_ORIGINS=https://your-stensibly-domain.example

# Optional exact Host header allowlist for deployments. Include ports when used.
STENSIBLY_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000
